  <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top shadow-sm">
    <div class="container-fluid">
        <!-- Brand/Logo with larger icon on mobile -->
        <a class="navbar-brand" href="/listing">
            <i class="fa-regular fa-compass fa-lg d-none d-md-inline"></i>
            <i class="fa-regular fa-compass fa-2x d-md-none"></i>
        </a>
        
        <!-- Toggle Button -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <!-- Collapsible Content -->
        <div class="collapse navbar-collapse" id="navbarContent">
            <!-- Left-aligned items -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" href="/listing">Explore</a>
                </li>
                <% if (currUser) { %>
                <li class="nav-item">
                    <a class="nav-link" href="/listing/new">New Listing</a>
                </li>
                <% } %>
            </ul>
            
            <!-- Search Form -->
            <form class="d-flex my-2 my-lg-0 mx-lg-3 flex-grow-1 flex-md-grow-0" role="search" method="post" action="/search">
                <div class="input-group w-100">
                    <input class="form-control search-space" name="search" type="search" 
                           placeholder="Search Listing" aria-label="Search">
                    <button class="btn btn-outline-success search-btn" type="submit">Search</button>
                </div>
            </form>
            
            <!-- Right-aligned items -->
            <ul class="navbar-nav mb-2 mb-lg-0">
                <% if (!currUser || currUser === null) { %>
                <li class="nav-item">
                    <a class="nav-link" href="/signup"><b>SignUp</b></a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/login"><b>LogIn</b></a>
                </li>
                <% } %>
                <% if (currUser) { %>
                <li class="nav-item">
                    <a class="nav-link" href="/logout"><b>LogOut</b></a>
                </li> 
                <% } %>
            </ul>
        </div>
    </div>
</nav>